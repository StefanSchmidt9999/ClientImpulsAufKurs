@page "/personen"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using HelloSoapService.Services
@using System.Xml.Linq
@using System.Text
@inject HelloSoapService Service

<PageTitle>Personen</PageTitle>

<h1>Personen</h1>

<h1>Personen</h1>

<button class="btn btn-primary mb-3"
        @onclick="Refresh">
    🔄 Aktualisieren
</button>

@if (!geladen)
{
    <div class="alert alert-info">Daten werden von Azure geladen...</div>
}
else if (!string.IsNullOrWhiteSpace(fehler))
{
    <div class="alert alert-danger">@fehler</div>
}
else if (personen.Count == 0)
{
    <div class="alert alert-warning">Keine Personendaten vorhanden.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Vorname</th>
                <th>Mittelname</th>
                <th>Nachname</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in personen)
            {
                <tr>
                    <td>@p.FirstName</td>
                    <td>@p.MiddleName</td>
                    <td>@p.LastName</td>
                </tr>
            }
        </tbody>
    </table>
}

@code 
{
    private bool geladen;
    private string? fehler;
    private bool ladevorgangGestartet;
    private List<PersonRow> personen = new();

    protected override async Task OnInitializedAsync()
    {
        await LadePersonenAsync();
    }

    private class PersonRow
    {
        public string FirstName { get; set; } = "";
        public string MiddleName { get; set; } = "";
        public string LastName { get; set; } = "";
    }

    private static string HexToUnicodeString(string hex)
    {
        hex = hex.Trim();

        byte[] bytes = new byte[hex.Length / 2];

        for (int i = 0; i < bytes.Length; i++)
        {
            bytes[i] = Convert.ToByte(hex.Substring(i * 2, 2), 16);
        }

        return Encoding.Unicode.GetString(bytes);
    }

    private static string HexToUtf8String(string hex)
    {
        hex = hex.Trim();

        byte[] bytes = new byte[hex.Length / 2];

        for (int i = 0; i < bytes.Length; i++)
        {
            bytes[i] = Convert.ToByte(hex.Substring(i * 2, 2), 16);
        }

        return Encoding.UTF8.GetString(bytes);
    }

    private async Task Refresh()
    {
        ladevorgangGestartet = false;
        geladen = false;
        await LadePersonenAsync();
    }

    private async Task LadePersonenAsync()
    {
        try
        {
            if (ladevorgangGestartet)
            {
                return;
            }

            ladevorgangGestartet = true;

            string? xml = await Service.GetResponseAsync();

            if (string.IsNullOrWhiteSpace(xml))
            {
                geladen = true;
                return;
            }


            // XDocument responseDoc = XDocument.Parse(xml);
            XDocument responseDoc = XDocument.Parse(xml);

            // string? hexData = responseDoc.Descendants("Data").FirstOrDefault()?.Value;

            // if (responseDoc.IsNullOrWhiteSpace(xml))
            // {
            //     fehler = "Keine Data-Daten in der Antwort gefunden.";
            //     return;
            // }

            // string personsXml = HexToUnicodeString(hexData);
            // string personsXml = HexToUtf8String(hexData);

            // XDocument personsDoc = XDocument.Parse(personsXml);

            personen = responseDoc.Descendants("Person")
                .Select(x => new PersonRow
                {
                    FirstName = x.Element("FirstName")?.Value ?? "",
                    MiddleName = x.Element("MiddleName")?.Value ?? "",
                    LastName = x.Element("LastName")?.Value ?? ""
                })
                .ToList();
        }
        catch (Exception ex)
        {
            fehler = "Fehler beim Laden: " + ex.Message;
        }
        finally
        {
            geladen = true;
        }
    }
    }
}