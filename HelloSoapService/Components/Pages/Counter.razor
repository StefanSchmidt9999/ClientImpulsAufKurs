@page "/counter"
@rendermode InteractiveServer
@using HelloSoapService.Services
@inject HelloSoapService Service
@inject HttpClient Http
@inject ClientIdService ClientIdService

<PageTitle>Nachricht an Azure schicken</PageTitle>

<h1>Nachricht an Azure schicken</h1>

@if (!clientChecked)
{
    <div class="alert alert-info">
        Lokaler Clientdienst wird geprüft...
    </div>
}
else if (!clientAllowed)
{
    <div class="alert alert-danger">
        <h4>Zugriff nicht möglich</h4>
        <p>@clientError</p>
    </div>

    return;
}
else
{
    <div class="alert alert-success">
        ClientId erkannt: @clientId
    </div>
}



<div class="mb-3">
    <label class="form-label">Nachricht</label>
    <input class="form-control"
           @bind="eingabeText"
           @bind:event="oninput"
           placeholder="Nachricht eingeben..." />
</div>

<button class="btn btn-primary"
        @onclick="LoadData"
        disabled="@(loading || string.IsNullOrWhiteSpace(eingabeText))">
    An Azure Web-App schicken
</button>

@if (loading)
{
    <p>Lade Daten...</p>
}
else if (!string.IsNullOrWhiteSpace(message))
{
    <p><strong>Antwort:</strong> @message</p>
}
else if (!string.IsNullOrWhiteSpace(error))
{   
    <div class="alert alert-danger mt-3">
        <strong>Fehler:</strong> @error
    </div>
}

@code {
    private string eingabeText = "";
    private string? message;
    private string? error;
    private bool loading;

    private string? clientId;
    private bool clientChecked;
    private bool clientAllowed;
    private string? clientError;

    private async Task LoadData()
    {
        if (loading)
        {
            return;
        }

        try
        {
            loading = true;
            message = null;
            error = null;

            var requestText = eingabeText;
            eingabeText = string.Empty;

            bool internetOk = await CheckInternetAsync();

            if (!internetOk)
            {
                error = "FEHLER: Keine Internetverbindung vorhanden.";
                return;
            }

            bool azureOk = await CheckAzureAsync();

            if (!azureOk)
            {
                error = "FEHLER: Azure Web-App ist nicht erreichbar.";
                return;
            }

            message = await Service.GetHelloMessageAsync(requestText);
        }
        catch (Exception ex)
        {
            error = "FEHLER: " + ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
    private async Task<bool> CheckInternetAsync()
    {
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(3));

            using var response = await Http.GetAsync(
                "https://www.microsoft.com",
                cts.Token);

            return response.IsSuccessStatusCode;
        }
        catch
        {
            return false;
        }
    }

    private async Task<bool> CheckAzureAsync()
    {
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(5));

            using var response = await Http.GetAsync(
                "https://mysoapapp-eqdtckhxd0enegft.canadacentral-01.azurewebsites.net/api/hello/ping",
                cts.Token);

            return response.IsSuccessStatusCode;
        }
        catch
        {
            return false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            clientId = await ClientIdService.GetClientIdAsync();

            if (string.IsNullOrWhiteSpace(clientId))
            {
                clientAllowed = false;
                clientError = "Keine gültige ClientId vom lokalen Dienst erhalten.";
            }
            else
            {
                clientAllowed = true;
            }
        }
        catch (Exception ex)
        {
            clientAllowed = false;
            clientError = "Lokaler Clientdienst ist nicht erreichbar: " + ex.Message;
        }
        finally
        {
            clientChecked = true;
        }
    }

}